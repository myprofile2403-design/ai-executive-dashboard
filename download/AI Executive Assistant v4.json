    {
      "parameters": {
        "name": "save_event",
        "description": "Save an event to the database. ALWAYS use this for every user message. Types: expense (purchase/spending), task (something to do), meeting (scheduled call/meeting), reminder (remind at specific time), note (thought/idea).",
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/events",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Prefer",
              "value": "return=representation"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: $json.type, title: $json.title, amount: $json.amount || null, currency: $json.currency || null, person: $json.person || null, project: $json.project || null, event_datetime: $json.event_datetime || null, due_datetime: $json.due_datetime || null, status: $json.status || 'open', metadata: {}, raw_text: $json.raw_text, transcript: $json.raw_text, telegram_chat_id: String($('Telegram Trigger').item.json.message.chat.id), telegram_message_id: String($('Telegram Trigger').item.json.message.message_id), audio_file_id: null, source: 'telegram', source_type: $('Set Text').first().json.source_type || $('Set Transcript').first().json.source_type || 'text' }) }}",
        "schema": "{\"type\": \"object\", \"properties\": {\"type\": {\"type\": \"string\", \"enum\": [\"expense\", \"task\", \"meeting\", \"reminder\", \"note\"], \"description\": \"Type of event\"}, \"title\": {\"type\": \"string\", \"description\": \"Short title\"}, \"amount\": {\"type\": \"number\", \"description\": \"Amount (only for expenses)\"}, \"currency\": {\"type\": \"string\", \"enum\": [\"UAH\", \"USD\", \"EUR\"], \"description\": \"Currency code\"}, \"person\": {\"type\": \"string\", \"description\": \"Person name\"}, \"project\": {\"type\": \"string\", \"description\": \"Project name\"}, \"event_datetime\": {\"type\": \"string\", \"description\": \"Event date/time ISO 8601\"}, \"due_datetime\": {\"type\": \"string\", \"description\": \"Due date/time ISO 8601\"}, \"status\": {\"type\": \"string\", \"enum\": [\"open\", \"done\", \"scheduled\"], \"description\": \"Status\"}, \"raw_text\": {\"type\": \"string\", \"description\": \"Original user message\"}}, \"required\": [\"type\", \"title\", \"raw_text\"]}",
        "options": {}
      },
      "id": "tool-save-event",
      "name": "Save Event",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        400,
        580
      ]
    },
    {
      "parameters": {
        "name": "query_events",
        "description": "Query events from the database. Use this when the user asks to see their expenses, tasks, meetings, reminders, notes, or wants a summary/report.",
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/events?select=id,type,title,amount,currency,person,project,event_datetime,due_datetime,status,created_at&order=created_at.desc&limit=20&type=eq.{{$json.filter_type}}&status=eq.{{$json.filter_status}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "={{$env.SUPABASE_KEY}}"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.SUPABASE_KEY}}"
            }
          ]
        },
        "options": {},
        "schema": "{\"type\": \"object\", \"properties\": {\"filter_type\": {\"type\": \"string\", \"enum\": [\"expense\", \"task\", \"meeting\", \"reminder\", \"note\", \"\"], \"description\": \"Filter by type. Empty = all\"}, \"filter_status\": {\"type\": \"string\", \"enum\": [\"open\", \"done\", \"scheduled\", \"\"], \"description\": \"Filter by status. Empty = all\"}}, \"required\": []}",
        "placeholderDefinitions": {
          "values": [
            {
              "name": "filter_type",
              "description": "Event type filter (expense, task, meeting, reminder, note, or empty for all)",
              "type": "string"
            },
            {
              "name": "filter_status",
              "description": "Status filter (open, done, scheduled, or empty for all)",
              "type": "string"
            }
          ]
        }
      },
      "id": "tool-query-events",
      "name": "Query Events",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
      "position": [
        400,
        740
      ]
